{
  "compilerOptions": {
    /* Paths de entrada y salida */
    "rootDir": ".",
    "outDir": "./dist",

    /* Compatibilidad del lenguaje */
    "target": "ES2022", // Buen soporte de funcionalidades modernas
    "module": "ESNext", // Permite tree-shaking con bundlers modernos
    "lib": ["ESNext"], // Soporte navegador y moderno
    // tal vez se nesecite esto: pnpm add -D @types/node

    /* Interoperabilidad con CommonJS */
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* Verificación estricta y seguridad */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,

    /* Salidas opcionales */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Otros ajustes recomendados */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "mocha"]
  },

  /* Archivos del proyecto */
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
